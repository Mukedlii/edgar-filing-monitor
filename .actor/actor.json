{
    "actorSpecification": 1,
    "name": "edgar-filing-monitor",
    "title": "SEC EDGAR Filing Monitor — 8-K, Insider Trading & 13F",
    "description": "Track SEC EDGAR filings by ticker: 8-K material events, Form 4 insider trades, 13F institutional holdings. Delta mode, Telegram alerts, webhook support. No proxy needed.",
    "version": "1.0",
    "buildTag": "latest",
    "dockerfile": "./Dockerfile",
    "readme": "./README.md",
    "input": "./input_schema.json",
    "storages": {
        "dataset": {
            "actorSpecification": 1,
            "fields": {},
            "views": {
                "overview": {
                    "title": "Filings overview",
                    "transformation": {
                        "fields": [
                            "ticker",
                            "form_type",
                            "company_name",
                            "filing_date",
                            "alert_type",
                            "insider_name",
                            "total_value_usd",
                            "document_url"
                        ]
                    },
                    "display": {
                        "component": "table",
                        "properties": {
                            "ticker": { "label": "Ticker", "format": "text" },
                            "form_type": { "label": "Form", "format": "text" },
                            "company_name": { "label": "Company", "format": "text" },
                            "filing_date": { "label": "Date", "format": "date" },
                            "alert_type": { "label": "Type", "format": "text" },
                            "insider_name": { "label": "Insider", "format": "text" },
                            "total_value_usd": { "label": "Value USD", "format": "number" },
                            "document_url": { "label": "Filing", "format": "link" }
                        }
                    }
                }
            }
        }
    }
}
